# DHAN API Credentials (from https://www.dhan.co/settings/api)
# Get your credentials from DHAN dashboard and uncomment below
DHAN_CLIENT_ID=your_client_id_from_dhan_dashboard
DHAN_CLIENT_SECRET=your_client_secret_from_dhan_dashboard

# Flask Configuration
SECRET_KEY=change-this-to-a-random-secret-key-in-production
FLASK_ENV=development
FLASK_DEBUG=True

# Server Configuration
SERVER_HOST=127.0.0.1
SERVER_PORT=5000

# DHAN Callback URL (must match configured in DHAN dashboard)
DHAN_CALLBACK_URL=http://127.0.0.1:5000/dhan/callback
